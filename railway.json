{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "phases": {
        "install": {
          "cmd": "npm install"
        },
        "build": {
          "cmd": ""
        },
        "start": {
          "cmd": "node backend/server.js"
        }
      }
    }
  },
  "deploy": {
    "startCommand": "node backend/server.js",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
